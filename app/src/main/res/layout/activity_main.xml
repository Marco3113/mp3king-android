<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#0a0a0a">
    <WebView android:id="@+id/webView" android:layout_width="match_parent" android:layout_height="match_parent"/>
    <ProgressBar android:id="@+id/progressBar" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent" android:layout_height="4dp" android:layout_alignParentTop="true"
        android:progressTint="#ffff00" android:max="100" android:visibility="gone"/>
    <TextView android:id="@+id/errorView" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_centerInParent="true" android:gravity="center" android:padding="32dp"
        android:text="⚠️ Nessuna connessione" android:textColor="#ffff00" android:textSize="18sp" android:visibility="gone"/>
    
</RelativeLayout>